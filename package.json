{
  "name": "book-website",
  "version": "1.0.0",
  "description": "Personal book tracker with login, want-to-read and already-read lists, search via Open Library.",
  "main": "server.js",
  "scripts": {
    "start":          "node server.js",
    "test:unit":      "node --test tests/unit/utils.test.js",
    "test:api":       "node --test tests/api/api.test.js",
    "test:db":        "node --test tests/db/schema.test.js",
    "test:security":  "node --test tests/security/security.test.js",
    "test:e2e":       "npx playwright test",
    "test":           "node --test tests/unit/utils.test.js && node --test tests/api/api.test.js && node --test tests/db/schema.test.js && node --test tests/security/security.test.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "express-session": "^1.18.0",
    "nodemailer": "^9.0.1",
    "playwright": "^1.61.1"
  },
  "allowScripts": {
    "bcrypt@5.1.1": true,
    "better-sqlite3@11.10.0": true
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
