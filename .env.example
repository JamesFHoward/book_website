# Copy this file to .env and fill in your values
# (Gmail: generate an App Password at myaccount.google.com/apppasswords)

SESSION_SECRET=change-this-to-a-long-random-string

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=Bookshelf <you@gmail.com>

# Base URL used in password-reset links and OAuth callback URLs
APP_URL=http://localhost:3000

# Google OAuth — create credentials at console.cloud.google.com
# (APIs & Services → Credentials → Create OAuth 2.0 Client ID)
# Set Authorised redirect URI to: $APP_URL/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — create app at github.com/settings/developers
# Set Authorization callback URL to: $APP_URL/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
